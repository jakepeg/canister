# Copied to .env.production for `vite build` / `npm run deploy:ic`.
# Must be https and publicly reachable (not loopback). Origin only — do not append /payments.
# Stripe Dashboard webhook URL: ${VITE_PAYMENTS_RELAY_BASE_URL}/payments/stripe/webhook
#
# Same host + path proxy: https://canister.co + reverse-proxy /payments/* to the relay
# Subdomain relay: https://payments.example.com
VITE_PAYMENTS_RELAY_BASE_URL=https://canister.co
